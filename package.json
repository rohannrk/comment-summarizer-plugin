{
  "name": "figma-comment-summarizer",
  "version": "0.1.0",
  "description": "Figma plugin that summarizes comments on a frame, section, or page into a clean summary + action items (BYOK: Gemini or local LLM).",
  "license": "MIT",
  "scripts": {
    "build": "node build.js",
    "build:prod": "node build.js --prod",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
